# Environment Variables — copy this file to .env and fill in your values

# MongoDB connection string (from MongoDB Atlas or local instance)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nutritionDB?retryWrites=true&w=majority

# Secret key used to sign and verify JWT tokens (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Port the Express server will listen on (not used on Vercel)
PORT=8000

# Your deployed Vercel frontend URL — used by the CORS config in production
# Example: https://nutrition-assistant.vercel.app
CLIENT_URL=https://your-app-name.vercel.app
